---
const games = [
  {
    name: 'Connect 4',
    tagline: 'Two players. One board. One winner.',
    description: 'Classic Connect 4 with a WebRTC data channel carrying moves. Solo mode uses a depth-6 minimax CPU.',
    href: 'https://lettfeti.github.io/c4/',
    players: '2 players',
    accent: '#e63946',
    accent2: '#f4d35e',
    icon: 'c4',
  },
  {
    name: 'Artillery',
    tagline: 'Turn-based combat on a distant world.',
    description: 'Scorched-Earth-style artillery duel. Destructible bitmap terrain, four weapons, wind, fall damage. 2–4 players.',
    href: 'https://lettfeti.github.io/artillery/',
    players: '2–4 players',
    accent: '#4dd0ff',
    accent2: '#a06cff',
    icon: 'artillery',
  },
  {
    name: 'Snake 2',
    tagline: 'Two snakes. One board. Don’t crash.',
    description: 'Retro-flavoured 2-player snake. Shared pellets, classic rules, swipe or d-pad controls. Portrait-first.',
    href: 'https://lettfeti.github.io/s2/',
    players: '2 players',
    accent: '#7fff6a',
    accent2: '#ff6ac0',
    icon: 'snake',
  },
  {
    name: 'Tanks',
    tagline: 'Turret duel in a brick-and-sand maze.',
    description: '2–4 player top-down tank fight. Mines, loot drops, short teleports, and walls that crumble. Virtual joystick, portrait-first.',
    href: 'https://lettfeti.github.io/t6/',
    players: '2–4 players',
    accent: '#7a8b3f',
    accent2: '#b3814a',
    icon: 'tanks',
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Games — Björn Orri Guðmundsson</title>
    <meta name="description" content="Small browser games I built for playing with friends and family. All peer-to-peer, no accounts, no install." />
    <meta property="og:title" content="Games — lettfeti.com" />
    <meta property="og:description" content="Small browser games. All peer-to-peer, no accounts, no install." />
    <meta property="og:url" content="https://lettfeti.com/games" />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Roboto+Slab:wght@400;700&display=swap" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --color-bg: #F8F8FA;
        --color-text: #18181E;
        --color-muted: #3F3D56;
        --color-accent: #5A4DDE;
        --color-accent-hover: #342B99;
        --color-border: #E2E2E9;
        --color-card: #ffffff;
        --font-body: 'Poppins', system-ui, sans-serif;
        --font-display: 'Roboto Slab', Georgia, serif;
      }
      html {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-body);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      body { min-height: 100vh; display: flex; flex-direction: column; align-items: center; }
      main { width: 100%; max-width: 720px; padding: 5rem 2rem 4rem; display: flex; flex-direction: column; gap: 2.5rem; }

      header { display: flex; flex-direction: column; gap: 0.75rem; }
      .eyebrow {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--color-accent);
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      h1 {
        font-family: var(--font-display);
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1.15;
        color: var(--color-text);
      }
      .lede {
        font-size: 1.0625rem;
        color: var(--color-muted);
        max-width: 48ch;
      }

      .games {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      .game {
        display: grid;
        grid-template-columns: 72px 1fr auto;
        align-items: center;
        gap: 1.25rem;
        padding: 1.25rem 1.5rem;
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-radius: 14px;
        text-decoration: none;
        color: inherit;
        transition: transform 140ms ease, box-shadow 200ms ease, border-color 200ms ease;
      }
      .game:hover, .game:focus-visible {
        border-color: var(--color-accent);
        box-shadow: 0 12px 30px rgba(90, 77, 222, 0.12);
        transform: translateY(-2px);
        outline: none;
      }
      .icon {
        width: 72px;
        height: 72px;
        border-radius: 12px;
        background: #0b1220;
        flex-shrink: 0;
        position: relative;
        overflow: hidden;
      }
      .icon svg { width: 100%; height: 100%; display: block; }

      .meta { min-width: 0; }
      .meta h2 {
        font-family: var(--font-display);
        font-size: 1.35rem;
        font-weight: 700;
        line-height: 1.2;
      }
      .meta .tagline {
        font-size: 0.9375rem;
        color: var(--color-muted);
        margin-top: 0.15rem;
      }
      .meta .desc {
        font-size: 0.875rem;
        color: var(--color-muted);
        margin-top: 0.5rem;
      }
      .players {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--color-muted);
        background: #EFEFF6;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
        margin-top: 0.5rem;
        letter-spacing: 0.02em;
      }
      .cta {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--color-accent);
        flex-shrink: 0;
      }
      .cta svg { width: 16px; height: 16px; fill: currentColor; transition: transform 140ms ease; }
      .game:hover .cta svg { transform: translateX(3px); }

      footer {
        padding-top: 1rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        gap: 1.5rem;
        font-size: 0.875rem;
      }
      footer a { color: var(--color-muted); text-decoration: none; font-weight: 500; }
      footer a:hover { color: var(--color-accent); }

      @media (max-width: 640px) {
        main { padding: 3rem 1.25rem 3rem; gap: 2rem; }
        h1 { font-size: 2rem; }
        .game { grid-template-columns: 56px 1fr; padding: 1rem 1.1rem; gap: 1rem; }
        .icon { width: 56px; height: 56px; }
        .cta { grid-column: 1 / -1; justify-self: end; }
        .meta .desc { display: none; }
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <span class="eyebrow">Play</span>
        <h1>Games</h1>
        <p class="lede">Small browser games I built for cabin weekends and long plane rides. All peer-to-peer, no accounts, no install — open the link on two devices and share the code.</p>
      </header>

      <section class="games">
        {games.map((g) => (
          <a class="game" href={g.href} target="_blank" rel="noopener noreferrer">
            <span class="icon" aria-hidden="true">
              {g.icon === 'c4' && (
                <svg viewBox="0 0 64 64">
                  <rect width="64" height="64" rx="10" fill="#1e6bcc" />
                  <circle cx="20" cy="22" r="8" fill="#e63946" />
                  <circle cx="44" cy="22" r="8" fill="#0b1733" />
                  <circle cx="20" cy="44" r="8" fill="#0b1733" />
                  <circle cx="44" cy="44" r="8" fill="#f4d35e" />
                </svg>
              )}
              {g.icon === 'artillery' && (
                <svg viewBox="0 0 64 64">
                  <rect width="64" height="64" rx="10" fill="#070a1a" />
                  <circle cx="46" cy="20" r="10" fill="#a06cff" />
                  <circle cx="20" cy="40" r="14" fill="#4dd0ff" />
                  <circle cx="17" cy="37" r="2" fill="#070a1a" />
                  <circle cx="25" cy="37" r="2" fill="#070a1a" />
                </svg>
              )}
              {g.icon === 'snake' && (
                <svg viewBox="0 0 64 64">
                  <rect width="64" height="64" rx="10" fill="#0b1016" />
                  <rect x="10" y="28" width="8" height="8" fill="#7fff6a" />
                  <rect x="18" y="28" width="8" height="8" fill="#7fff6a" />
                  <rect x="26" y="28" width="8" height="8" fill="#7fff6a" />
                  <rect x="34" y="20" width="8" height="8" fill="#7fff6a" />
                  <rect x="46" y="42" width="8" height="8" rx="4" fill="#ff6ac0" />
                </svg>
              )}
              {g.icon === 'tanks' && (
                <svg viewBox="0 0 64 64">
                  <rect width="64" height="64" rx="10" fill="#1b1d16" />
                  <rect x="16" y="28" width="32" height="22" rx="3" fill="#7a8b3f" />
                  <rect x="22" y="22" width="20" height="10" rx="2" fill="#9cb157" />
                  <rect x="32" y="14" width="4" height="14" fill="#7a8b3f" />
                  <rect x="12" y="48" width="40" height="4" rx="2" fill="#4c5227" />
                  <circle cx="20" cy="50" r="2.5" fill="#0f1109" />
                  <circle cx="44" cy="50" r="2.5" fill="#0f1109" />
                </svg>
              )}
            </span>
            <div class="meta">
              <h2>{g.name}</h2>
              <div class="tagline">{g.tagline}</div>
              <div class="desc">{g.description}</div>
              <span class="players">{g.players}</span>
            </div>
            <span class="cta">
              Play
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h12M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        ))}
      </section>

      <footer>
        <a href="/">← Home</a>
        <a href="https://github.com/lettfeti" target="_blank" rel="noopener noreferrer">Source on GitHub</a>
      </footer>
    </main>
  </body>
</html>
